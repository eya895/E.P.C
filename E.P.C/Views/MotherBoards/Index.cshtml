@model List<E.P.C.Models.MotherBoard>

<div class="epc-products">
    <div class="container py-5">

        <h2 class="text-white mb-4">Motherboards</h2>

        <div class="row g-4">

            @foreach (var motherboard in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="product-card">

                        <div class="image-wrapper">
                            <img src="@motherboard.ImageUrl" class="product-img" />
                        </div>

                        <div class="text-center p-3">
                            <h5 class="modelname">@motherboard.Brand @motherboard.Model</h5>
                            <p class="price">₪@motherboard.Price</p>

                            <a asp-action="Details"
                                   asp-route-id="@motherboard.Id"
                                   class="btn-details">
                                View Details
                            </a>

                            <a asp-controller="PcBuilder"
                                   asp-action="SelectMotherboard"
                                   asp-route-id="@motherboard.Id"
                                   class="btn-buy">
                                Select
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</div>

<style>
    .epc-products {
        min-height: 100vh;
        background: radial-gradient(circle at top, rgba(0,242,254,0.08), transparent 40%), radial-gradient(circle at bottom, rgba(79,172,254,0.06), transparent 50%), radial-gradient(circle at center, #1a2235 0%, #0b0f19 100%);
        color: white;
    }

    .product-card {
        background: rgba(22, 30, 46, 0.95);
        border-radius: 18px;
        border: 1px solid rgba(0, 242, 254, 0.25);
        overflow: hidden;
        transition: 0.3s ease;
        box-shadow: 0 20px 40px rgba(0,0,0,0.6);
    }

        .product-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 30px 70px rgba(0, 242, 254, 0.18), 0 0 25px rgba(0, 242, 254, 0.12);
            border-color: rgba(0, 242, 254, 0.5);
        }

    .image-wrapper {
        height: 220px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .modelname {
        font-weight: 700;
    }

    .price {
        font-size: 1.4rem;
        color: #00f2fe;
        font-weight: 900;
    }

    /* SAME BUTTON STYLE AS BUILDER */
    .btn-details {
        background: rgba(0, 242, 254, 0.12);
        color: #00f2fe;
        border: 1px solid rgba(0, 242, 254, 0.45);
        font-weight: 800;
        padding: 12px;
        border-radius: 10px;
        display: block;
        text-align: center;
        text-decoration: none;
        transition: 0.25s ease;
        margin: 10px auto;
        backdrop-filter: blur(6px);
        box-shadow: 0 0 12px rgba(0, 242, 254, 0.15);
    }

        .btn-details:hover {
            background: rgba(0, 242, 254, 0.25);
            box-shadow: 0 0 15px rgba(0, 242, 254, 0.4), 0 0 35px rgba(0, 242, 254, 0.25);
            transform: scale(1.03);
        }

    .btn-buy {
        background: linear-gradient(90deg, #00f2fe, #4facfe);
        color: #0b0f19;
        font-weight: 800;
        padding: 12px;
        text-align: center;
        display: block;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(0, 242, 254, 0.5);
        transition: 0.25s;
        text-decoration: none;
    }

        .btn-buy:hover {
            transform: scale(1.02);
            box-shadow: 0 0 35px rgba(0, 242, 254, 0.8);
        }
</style>