@model E.P.C.Models.CPU

@{
    ViewData["Title"] = "CPU Details";
    ViewData["FullWidth"] = true;
}

<div class="epc-hero">
    <div class="product-card">

        <div class="row g-0">

            <!-- IMAGE -->
            <div class="col-lg-5 product-image-section">
                <div class="image-card">
                    <img src="@Model.ImageUrl" class="floating-img" />
                </div>
            </div>

            <!-- CONTENT -->
            <div class="col-lg-7 p-5">

                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="neon-badge">CPU</span>
                    <h2 class="price-tag">₪@Model.Price.ToString("N0")</h2>
                </div>

                <h1 class="product-title">
                    @Model.Brand @Model.Model
                </h1>

                <p class="product-description">
                   @Model.Description
                </p>

                <div class="specs-container">

                    <h5 class="specs-title">CPU Specifications</h5>

                    <div class="specs-grid">

                        <div class="spec-item">
                            <span>Cores</span>
                            <strong>@Model.Cores</strong>
                        </div>

                        <div class="spec-item">
                            <span>Threads</span>
                            <strong>@Model.Threads</strong>
                        </div>

                        <div class="spec-item">
                            <span>Base Clock</span>
                            <strong>@Model.BaseClock GHz</strong>
                        </div>

                        <div class="spec-item">
                            <span>Boost Clock</span>
                            <strong>@Model.BoostClock GHz</strong>
                        </div>

                        <div class="spec-item">
                            <span>Socket</span>
                            <strong>@Model.SocketType</strong>
                        </div>

                        <div class="spec-item">
                            <span>Integrated Graphics</span>
                            <strong>@(Model.IntegratedGraphics ? "Yes" : "No")</strong>
                        </div>

                    </div>

                </div>

                <div class="actions">

                    <a asp-action="Index" class="neon-outline-btn">
                        Back to CPUs
                    </a>

                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                    {
                        <form asp-controller="PcBuilder" asp-action="SelectCpu" method="post" class="flex-grow-1">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="neon-btn w-100">
                                Add to Build 🧩
                            </button>
                        </form>
                    }

                </div>

            </div>
        </div>

    </div>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
        background: #0b0f19;
    }

    .epc-hero {
        height: calc(100vh - 90px);
        overflow-y: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at center, #1a2235 0%, #0b0f19 100%);
        color: white;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    .product-card {
        background: rgba(22, 30, 46, 0.95);
        border: 1px solid rgba(0, 242, 254, 0.25);
        border-radius: 20px;
        max-width: 1100px;
        width: 100%;
        box-shadow: 0 25px 60px rgba(0,0,0,0.6);
        overflow: hidden;
    }

    /* ---------- IMAGE CARD ---------- */
    .product-image-section {
        background: transparent;
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .image-card {
        background: white;
        border-radius: 18px;
        padding: 18px;
        width: 125%;
        height: 100%;
        max-width: 420px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .floating-img {
        max-height: 420px;
        object-fit: contain;
        transition: 0.3s;
    }

    .neon-badge {
        background: rgba(0, 242, 254, 0.15);
        color: #7dd3fc;
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .price-tag {
        color: #00f2fe;
        font-weight: 900;
        text-shadow: 0 0 12px rgba(0, 242, 254, 0.4);
    }

    .product-title {
        font-weight: 900;
        margin-top: 0.5rem;
        margin-bottom: 1rem;
    }

    .product-description {
        color: #cbd5f5;
        font-size: 1.05rem;
        margin-bottom: 2.5rem;
    }

    .specs-title {
        font-weight: 800;
        margin-bottom: 1.5rem;
        letter-spacing: 1px;
        color: #7dd3fc;
    }

    .specs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 22px 14px;
    }

    .spec-item {
        border-left: 3px solid #00f2fe;
        padding-left: 12px;
    }

        .spec-item span {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 700;
        }

        .spec-item strong {
            font-size: 1.05rem;
            color: #e5e7eb;
        }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 3rem;
    }

    .neon-btn {
        padding: 14px 28px;
        border-radius: 50px;
        background: linear-gradient(90deg, #00f2fe, #4facfe);
        color: #0b0f19;
        font-weight: 900;
        border: none;
        box-shadow: 0 0 30px rgba(0, 242, 254, 0.5);
        transition: 0.25s;
    }

        .neon-btn:hover {
            transform: translateY(-2px) scale(1.04);
            box-shadow: 0 0 45px rgba(0, 242, 254, 0.8);
        }

    .neon-outline-btn {
        padding: 14px 28px;
        border-radius: 50px;
        border: 2px solid rgba(0, 242, 254, 0.5);
        color: #7dd3fc;
        font-weight: 800;
        text-decoration: none;
        transition: 0.25s;
    }

        .neon-outline-btn:hover {
            background: rgba(0, 242, 254, 0.1);
            color: #00f2fe;
        }
</style>